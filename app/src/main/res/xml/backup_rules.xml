<?xml version="1.0" encoding="utf-8"?>
<!--
    android:allowBackup="false" in AndroidManifest.xml is the primary control.
    This file is the companion required by API 31+ data extraction rules.
    No user data is backed up — privacy by design.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
