<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- NewPipeExtractor makes all HTTP calls via OkHttp on IO dispatcher -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required API 28+: any app starting a foreground service needs this -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required API 34+: without this, starting a service with
         foregroundServiceType="mediaPlayback" throws IllegalArgumentException -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Required API 33+: must ALSO request at runtime via ActivityCompat.requestPermissions().
         Without user grant, the media notification is silently suppressed on API 33+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".ExtraTubeApplication"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.ExtraTube">

        <!--
            configChanges: prevents Activity recreation on rotation/keyboard events.
            Compose handles layout changes via LocalConfiguration.current.
            Without this, rotation destroys ExoPlayer and resets navigation state.

            windowSoftInputMode=adjustResize: window shrinks when soft keyboard appears,
            keeping the search bar visible. adjustPan shifts the whole window (bad for
            Compose full-screen layouts).

            exported=true: Android 12+ requires this on activities with MAIN/LAUNCHER filter.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            exported=true: Media3 MediaSessionService must be exported so system UI
            (lock screen, notification shade, Android Auto) can bind to it.

            foregroundServiceType=mediaPlayback: Android 10+ requires this for the
            notification to survive screen-off. API 34+ requires the matching
            FOREGROUND_SERVICE_MEDIA_PLAYBACK permission.

            The MediaSessionService intent-filter lets the system discover this service
            for media button routing (volume keys, Bluetooth controls).

            NOTE: Do NOT call startForeground() in PlaybackService.
            Media3 MediaSessionService handles foreground management automatically.
        -->
        <service
            android:name=".service.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

    </application>

</manifest>
